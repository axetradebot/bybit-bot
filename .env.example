# Local Postgres/Timescale: from repo root run  docker compose up -d timescaledb
# Then keep DB_HOST=localhost (or 127.0.0.1) so Python hits the container.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bybit_shadow
DB_USER=bybit
DB_PASSWORD=changeme_strong_password

SYMBOLS=["SOLUSDT","AVAXUSDT","WIFUSDT","DOTUSDT","1000PEPEUSDT"]

TARDIS_API_KEY=your_tardis_api_key_here

BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=false
BYBIT_DEMO=true

LIVE_STRATEGY=sniper
LIVE_EQUITY=1000
LIVE_RISK_PCT=0.02

# Optional: CoinGlass Crypto API — never commit a real key
COINGLASS_API_KEY=
# COINGLASS_BASE_URL=https://open-api-v4.coinglass.com
# Hobbyist ~30 req/min; default 28 to stay under the cap
# COINGLASS_MAX_RPM=28
# Hobbyist: aggregated liquidation history needs interval >= 4h
# COINGLASS_MIN_INTERVAL=4h
# COINGLASS_EXCHANGE_LIST=Binance,Bybit,OKX
# COINGLASS_ENFORCE_HOBBYIST_LIMITS=true
# Bars per symbol per sync (API max 1000)
# COINGLASS_SYNC_LIMIT=240
